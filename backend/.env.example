# Copy this file to `.env` and fill in your own values.
# Never commit your real .env file.

# Your Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB connection string, e.g.:
# local:  mongodb://127.0.0.1:27017/interview-prep
# Atlas:  mongodb+srv://<user>:<password>@<cluster-url>/interview-prep
MONGODB_URI=mongodb://127.0.0.1:27017/interview-prep

# Port the Express server listens on
PORT=5000

# Comma-separated list of origins allowed to call this API
# e.g. http://localhost:3000,https://your-frontend.app
CORS_ORIGIN=http://localhost:3000
